{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group GitHub Actions updates into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ]
}
